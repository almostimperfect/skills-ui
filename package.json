{
  "name": "skills-ui",
  "version": "0.1.0",
  "description": "Visual management layer for vercel-labs/skills",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skills-ui": "./dist/cli/index.js"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "dev:server": "node --import tsx/esm src/cli/index.ts serve",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "skills": "^1.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "@tanstack/react-query": "^5.62.16",
    "tailwindcss": "^3.4.17",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
